nextflow_workflow {

    name "Test Subworkflow BAM2FASTQ_SUBWORKFLOW"
    script "../subworkflows/local/bam2fastq.nf"
    workflow "bam2fastq_subworkflow"

    tag "subworkflows"
    tag "subworkflows_local"
    tag "bam2fastq_subworkflow"
    tag "samtools"
    tag "samtools/fastq"

    test("Convert BAM to FASTQ") {

        when {
            params {
                outdir = "$outputDir"  // Fixed: Added the required outdir parameter
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'test' ],
                    file('${projectDir}/assets/test_data/test.bam', checkIfExists: true)
                ])

                input[1] = [[],[]]
                input[2] = [[],[]]
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.other != null },
                { assert workflow.out.versions != null },
                // Fixed: Added snapshot assertion for versions.yml
                { assert snapshot(workflow.out.versions).match("versions") }
            )
        }
    }

    test("Convert BAM to FASTQ - stub") {

        options "-stub"

        when {
            params {
                outdir = "$outputDir"  // Fixed: Added the required outdir parameter
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'test' ],
                    file('${projectDir}/assets/test_data/test.bam', checkIfExists: true)
                ])

                input[1] = [[],[]]
                input[2] = [[],[]]
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.other != null }
            )
        }
    }
}
