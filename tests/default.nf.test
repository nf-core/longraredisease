nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    test("-profile test") {

        tag 'non-stub'
        when {
            params {
                input = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/samplesheet_ubam.csv"
                outdir = "$outputDir"
                qc         = false
                methyl     = false
                run_svanna = false
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert path("$outputDir").exists() }
            )
        }
    }

    test("-profile test -stub") {

        tag "stub"
        options "-stub"

        when {
            params {
                input = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/samplesheet_ubam.csv"
                outdir = "$outputDir"
                qc         = false
                methyl     = false
                run_svanna = false
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert path("$outputDir").exists() },
                { assert snapshot(path("$outputDir/pipeline_info/nf_core_longraredisease_software_mqc_versions.yml").yaml).match("versions") }
            )
        }
    }
}
