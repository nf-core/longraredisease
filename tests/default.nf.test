nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    test("-profile test") {

        when {
            params {
                input = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/samplesheet_ubam.csv"
                outdir = "$outputDir"
            }
        }

        then {
            assertAll(
                { assert workflow.success },

                // Pipeline info
                { assert path("$outputDir/pipeline_info").exists() },
                { assert path("$outputDir/pipeline_info/nf_core_longraredisease_software_mqc_versions.yml").exists() },

                // Alignment (ubam input)
                { assert path("$outputDir/test/mapped_bam").exists() },
                { assert path("$outputDir/test/mapped_bam/test.bam").exists() },
                { assert path("$outputDir/test/mapped_bam/test.bam.bai").exists() },

                // BAM stats and coverage (generate_bam_stats=true, generate_coverage_report=true)
                { assert path("$outputDir/test/bam_stats").exists() },
                { assert path("$outputDir/test/mosdepth").exists() },

                // Haplotagging (haplotag_bam=true)
                { assert path("$outputDir/test/haplotagged_bam").exists() },

                // SV calling (sv=true, merge_sv=true)
                { assert path("$outputDir/test/sniffles").exists() },
                { assert path("$outputDir/test/cutesv").exists() },
                { assert path("$outputDir/test/svim").exists() },
                { assert path("$outputDir/test/merged_sv").exists() },

                // SNV calling (snv=true)
                { assert path("$outputDir/test/clair3").exists() },

                // STR analysis (str=true)
                { assert path("$outputDir/test/str").exists() },

                // Phasing
                { assert path("$outputDir/test/longphase").exists() }
            )
        }
    }
}
