nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    test("-profile test") {

        when {
            params {
                input = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/samplesheet_ubam.csv"
                outdir = "$outputDir"
                qc         = false
                methyl     = false
                run_svanna = false
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert path("$outputDir/pipeline_info").exists() },
                { assert path("$outputDir/pipeline_info").list().size() > 0 },
                { assert path("$outputDir/test").exists() },
                { assert path("$outputDir/test/mapped_bam").exists() },
                { assert path("$outputDir/test/bam_stats").exists() },
                { assert path("$outputDir/test/mosdepth").exists() },
                { assert path("$outputDir/test/sniffles").exists() },
                { assert path("$outputDir/test/clair3").exists() },
                { assert path("$outputDir/test/str").exists() },
                { assert path("$outputDir/pipeline_info/nf_core_longraredisease_software_mqc_versions.yml").exists() }
            )
        }
    }

    test("-profile test -stub") {

        options "-stub"

        when {
            params {
                input      = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/samplesheet_ubam.csv"
                outdir     = "$outputDir"
                qc         = false
                methyl     = false
                run_svanna = false
                unify_vcf  = false
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert path("$outputDir").exists() },
                { assert snapshot(path("$outputDir/pipeline_info/nf_core_longraredisease_software_mqc_versions.yml").yaml).match("versions") }
            )
        }
    }
}
