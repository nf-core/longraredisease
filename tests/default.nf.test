nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    test("-profile test") {

        when {
            params {
                input = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/samplesheet_ubam.csv"
                outdir = "$outputDir"
            }
        }

        then {
            // Basic success check
            assert workflow.success

            // Check output directory exists
            assert path("$outputDir").exists()

            // Check pipeline info directory exists
            assert path("$outputDir/pipeline_info").exists()
        }
    }
}
