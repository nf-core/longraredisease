nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    test("-profile test") {

        when {
            params {
                input = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/samplesheet_ubam.csv"
                outdir = "$outputDir"
                qc         = false
                methyl     = false
                run_svanna = false
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.stdout.findAll { !it.matches(".*(Downloading plugin|Staging foreign file|trace_report_suffix|runName|workDir|launchDir|configFiles|\\[PROCESS).*") },
                    workflow.stderr.findAll { !it.matches(".*(Downloading plugin|Staging foreign file).*") }
                ).match() }
            )
        }
    }

    test("-profile test -stub") {

        options "-stub"

        when {
            params {
                input = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/samplesheet_ubam.csv"
                outdir = "$outputDir"
                qc         = false
                methyl     = false
                run_svanna = false
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert path("$outputDir").exists() },
                { assert snapshot(path("$outputDir/pipeline_info/nf_core_longraredisease_software_mqc_versions.yml").name).match("versions") }
            )
        }
    }
}
