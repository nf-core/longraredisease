nextflow_pipeline {

    name "Test Complete Pipeline LONGRAREDISEASE"
    script "main.nf"

    tag "pipeline"
    tag "longraredisease"
    tag "integration"

    test("Complete pipeline - FASTQ alignment with all analyses") {

        when {
            params {
                // Input and output
                input = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/samplesheet_fastq.csv"
                outdir = "$outputDir"

                // Reference files
                fasta_file = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/genome_22/genome_22.fasta"
                straglr_bed = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/straglr/str.test.bed"
                trgt_bed = "${projectDir}/assets/data/trgt_repeat_catalog.hg38.bed"
                variant_catalogue = "${projectDir}/assets/data/annotate_str/variant_catalog_hg38.json"
                chromosome_codes = ['chr22']
                deepvariant_regions = 'chr22'
                sniffles_tandem_file = "${projectDir}/assets/data/sniffles_no_alt_analysis_set.trf.bed"
                winnowmap_kmers = "${projectDir}/assets/data/repetitive_k15.txt"

                // Main analysis toggles
                input_type = 'fastq'
                sequencing_platform = 'ont'
                use_winnowmap = false
                haplotag_bam = true
                trio_analysis = false

                // Enable major analyses (CNV disabled)
                generate_bam_stats = true
                generate_coverage_report = true
                qc = false
                sv = true
                snv = true
                cnv = false  // CNV disabled
                str = true
                methyl = false

                // SV parameters
                merge_sv = true
                filter_pass_sv = true
                annotate_sv = false
                rankfiltering = '3-5,NA'
                run_svim = true
                downsample_sv = true
                min_caller_support = 2

                // SNV parameters
                run_deepvariant = false
                filter_pass_snv = true
                clair3_model = "ont"
                clair3_platform = "ont"
                annotate_clair3 = true

                // CNV parameters (disabled but defined)
                hificnv_exclude_bed = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/hificnv/test.exclude.bed"
                use_test_data = true
                spectre_test_summary_txt = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/spectre/test.mosdepth.summary.txt"
                spectre_test_regions_bed = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/spectre/test.regions.bed.gz"
                spectre_test_regions_csi = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/spectre/test.regions.bed.gz.csi"
                spectre_test_fasta_file = "s3://ngi-igenomes/igenomes/Homo_sapiens/NCBI/GRCh38/Sequence/WholeGenomeFasta/genome.fa"
                spectre_test_clair3_vcf = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/spectre/test_clair3.vcf.gz"
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert path("$outputDir").exists() },

                // Check pipeline info
                { assert path("$outputDir/pipeline_info").exists() },
                { assert path("$outputDir/pipeline_info").list().size() > 0 },

                // Check alignment outputs
                { assert path("$outputDir/test/mapped_bam").exists() },

                // Check BAM stats if enabled
                { assert path("$outputDir/test/bam_stats").exists() },

                // Check coverage analysis
                { assert path("$outputDir/test/mosdepth").exists() },

                // Check SV calling outputs
                { assert path("$outputDir/test/sniffles").exists() },
                { assert path("$outputDir/test/svim").exists() },
                { assert path("$outputDir/test/cutesv").exists() },

                // Check SNV calling outputs
                { assert path("$outputDir/test/clair3").exists() },

                // Check STR analysis outputs
                { assert path("$outputDir/test/str").exists() },

                // Check phasing outputs
                { assert path("$outputDir/test/longphase").exists() },

                // Check that versions file is created
                { assert path("$outputDir/pipeline_info/nf_core_longraredisease_software_mqc_versions.yml").exists() }
            )
        }
    }

    test("Pipeline - stub mode (full pipeline)") {

        options "-stub"

        when {
            params {
                input = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/samplesheet_fastq.csv"
                outdir = "$outputDir"

                // Reference files
                fasta_file = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/genome_22/genome_22.fasta"
                straglr_bed = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/straglr/str.test.bed"
                trgt_bed = "${projectDir}/assets/data/trgt_repeat_catalog.hg38.bed"
                chromosome_codes = ['chr22']
                sniffles_tandem_file = "${projectDir}/assets/data/sniffles_no_alt_analysis_set.trf.bed"

                // Enable all analyses for comprehensive stub testing (CNV disabled)
                input_type = 'fastq'
                use_winnowmap = false
                generate_bam_stats = true
                generate_coverage_report = true
                qc = true
                sv = true
                snv = true
                cnv = false  // CNV disabled
                str = true
                methyl = false

                // All optional features
                merge_sv = true
                filter_pass_sv = true
                run_deepvariant = false
                annotate_sv = false
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert path("$outputDir").exists() }
            )
        }
    }

    test("Pipeline - error handling (missing input)") {

        when {
            params {
                input = "/non/existent/samplesheet.csv"
                outdir = "$outputDir"
                fasta_file = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/genome_22/genome_22.fasta"
            }
        }

        then {
            assert workflow.failed
        }
    }

    test("Pipeline - parameter validation") {

        when {
            params {
                input = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/samplesheet_fastq.csv"
                outdir = "$outputDir"
                fasta_file = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/genome_22/genome_22.fasta"

                // Test with minimal parameters
                input_type = 'fastq'
                sv = true
                snv = true
                cnv = false
            }
        }

        then {
            // This might pass or fail depending on your validation logic
            // Adjust based on your parameter validation implementation
            assert workflow.success || workflow.failed
        }
    }
}
