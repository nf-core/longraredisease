nextflow_pipeline {

    name "Test Complete Pipeline LONGRAREDISEASE"
    script "main.nf"

    tag "pipeline"
    tag "longraredisease"
    tag "integration"

    test("Complete pipeline - FASTQ alignment with all analyses") {

        when {
            params {
                // Input and output
                input = "${projectDir}/assets/samplesheet_test_fastq.csv"
                outdir = "$outputDir"  // Fixed: Added the required outdir parameter

                // Reference files
                fasta_file = "${projectDir}/assets/test_data/genome_22/genome_22.fasta"
                str_bed_file = "${projectDir}/assets/test_data/straglr/str.test.bed"
                exclude_bed_hificnv = "${projectDir}/assets/test_data/test.exclude.bed"

                // Main analysis toggles
                input_type = 'fastq'
                use_winnowmap = false

                // Enable all major analyses
                generate_bam_stats = true
                generate_coverage = true
                qc = false
                sv = true
                snv = true
                cnv_hificnv = false
                cnv_spectre = false
                str = true
                phase = true
                methyl = false

                // SV parameters
                merge_sv = true
                filter_sv_pass = true
                annotate_sv = false

                // SNV parameters
                deepvariant = true
                merge_snv = true
                filter_pass_snv = true
                clair3_model = "ont"
                clair3_platform = "ont"

                // Phasing parameters
                phase_with_sv = true

                // VCF unification
                unify_geneyx = false

                // Test-specific settings
                use_test_data = false
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert path("$outputDir").exists() },

                // Check pipeline info
                { assert path("$outputDir/pipeline_info").exists() },
                { assert path("$outputDir/pipeline_info").list().size() > 0 },

                // Check alignment outputs
                { assert path("$outputDir/test/mapped_bam").exists() },

                // Check BAM stats if enabled
                { assert path("$outputDir/test/bam_stats").exists() },

                // Check coverage analysis
                { assert path("$outputDir/test/mosdepth").exists() },

                // Check SV calling outputs
                { assert path("$outputDir/test/sniffles").exists() },
                { assert path("$outputDir/test/svim").exists() },
                { assert path("$outputDir/test/cutesv").exists() },

                // Check SNV calling outputs
                { assert path("$outputDir/test/clair3").exists() },
                { assert path("$outputDir/test/deepvariant").exists() },

                // Check STR analysis outputs
                { assert path("$outputDir/test/straglr").exists() },

                // Check phasing outputs
                { assert path("$outputDir/test/longphase").exists() },

                // Check that versions file is created
                { assert path("$outputDir/pipeline_info/nf_core_longraredisease_software_versions.yml").exists() }
            )
        }
    }

    test("Complete pipeline - BAM alignment workflow") {

        when {
            params {
                input = "${projectDir}/assets/samplesheet_test_fastq.csv"
                outdir = "$outputDir"  // Fixed: Added the required outdir parameter

                // Reference files
                fasta_file = "${projectDir}/assets/test_data/genome_22/genome_22.fasta"
                str_bed_file = "${projectDir}/assets/test_data/straglr/str.test.bed"
                exclude_bed_hificnv = "${projectDir}/assets/test_data/test.exclude.bed"

                // BAM alignment workflow
                input_type = 'fastq'
                use_winnowmap = false

                // Enable subset of analyses for faster testing
                generate_bam_stats = true
                generate_coverage = true
                qc = true
                sv = true
                snv = true
                cnv_hificnv = false
                cnv_spectre = false
                str = false
                phase = false
                methyl = false

                // SV parameters
                merge_sv = false
                filter_sv_pass = true
                sv_caller = 'sniffles'

                // SNV parameters
                deepvariant = false
                merge_snv = false
                filter_pass_snv = true
                clair3_model = "ont"
                clair3_platform = "ont"
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert path("$outputDir").exists() },
                { assert path("$outputDir/pipeline_info").exists() },
                { assert path("$outputDir/test/bam_stats").exists() },
                { assert path("$outputDir/test/nanoplot_qc").exists() },
                { assert path("$outputDir/test/sniffles").exists() },
                { assert path("$outputDir/test/clair3").exists() }
            )
        }
    }

    test("Pipeline - stub mode (full pipeline)") {

        options "-stub"

        when {
            params {
                input = "${projectDir}/assets/samplesheet_test_fastq.csv"
                outdir = "$outputDir"  // Fixed: Added the required outdir parameter

                // Reference files
                fasta_file = "${projectDir}/assets/test_data/genome_22/genome_22.fasta"
                str_bed_file = "${projectDir}/assets/test_data/straglr/str.test.bed"
                exclude_bed_hificnv = "${projectDir}/assets/test_data/test.exclude.bed"

                // Enable all analyses for comprehensive stub testing
                input_type = 'fastq'
                use_winnowmap = false
                generate_bam_stats = true
                generate_coverage = true
                qc = true
                sv = true
                snv = false
                cnv_hificnv = true
                cnv_spectre = false
                str = true
                phase = true
                methyl = false

                // All optional features
                merge_sv = true
                filter_sv_pass = true
                deepvariant = false
                merge_snv = false
                phase_with_sv = true
                unify_geneyx = false
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert path("$outputDir").exists() }
            )
        }
    }

    test("Pipeline - error handling (missing input)") {

        when {
            params {
                input = "/non/existent/samplesheet.csv"
                outdir = "$outputDir"  // Fixed: Added the required outdir parameter
                fasta_file = "${projectDir}/assets/test_data/genome_22/genome_22.fasta"
            }
        }

        then {
            assert workflow.failed
        }
    }

    test("Pipeline - parameter validation") {

        when {
            params {
                input = "${projectDir}/assets/samplesheet_test_fastq.csv"
                outdir = "$outputDir"  // Fixed: Added the required outdir parameter
                fasta_file = "${projectDir}/assets/test_data/genome_22/genome_22.fasta"

                // Test conflicting parameters
                input_type = 'fastq'
            }
        }

        then {
            // This might pass or fail depending on your validation logic
            // Adjust based on your parameter validation implementation
            assert workflow.success || workflow.failed
        }
    }
}
