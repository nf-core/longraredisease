nextflow_pipeline {

    name "Test Workflow main.nf"
    script "main.nf"

    test("Should run without failures") {

        when {
            params {
                outdir = "$outputDir"
                input = 'https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/samplesheet/samplesheet.csv'  // Add test input
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    UTILS.removeNextflowVersion("$outputDir"),
                    path("$outputDir/pipeline_info/software_versions.yml").readLines().first().contains("PIPELINE:")
                ).match("software_versions") }
            )
        }
    }
}
