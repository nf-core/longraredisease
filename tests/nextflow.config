/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running nf-test
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Layered on top of the `test` profile (conf/test.config), which is applied via
    nf-test.config. Only parameters that differ from the main nextflow.config defaults
    or that intentionally override conf/test.config are defined here.
----------------------------------------------------------------------------------------
*/
params {
    config_profile_name          = 'Test profile'
    config_profile_description   = 'Minimal test dataset to check pipeline function'
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/'
    modules_testdata_base_path   = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
    igenomes_ignore              = true // avoid accessing s3 iGenomes during tests

    // ========================================
    // Overrides of conf/test.config
    // ========================================
    cnv                         = true   // Enable CNV calling (Spectre/HiFiCNV)
    methyl                      = false
    run_svanna                  = false
    annotate_clair3             = true

    // ========================================
    // SV params that differ from main defaults
    // ========================================
    sniffles_min_mapq       = 10
    rankfiltering           = '3-5,NA' // Pathogenic or non pathogenic
    svim_min_mapq           = 10
    downsample_sv           = true
    cutesv_min_mapq         = 10
    svanna_db               = null // avoid S3 svanna DB lookup in tests

    // SNV annotation: small test database (default GRCh38.mane.1.2.ensembl is ~380MB and too slow for CI)
    snpeff_db               = 'WBcel235.115'

    // Spectre test parameters (main defaults are null)
    use_test_data                = true // Spectre cannot run on a data subset, so use prepared test data
    spectre_test_summary_txt     = params.pipelines_testdata_base_path + "longraredisease/spectre/test.mosdepth.summary.txt"
    spectre_test_regions_bed     = params.pipelines_testdata_base_path + "longraredisease/spectre/test.regions.bed.gz"
    spectre_test_regions_csi     = params.pipelines_testdata_base_path + "longraredisease/spectre/test.regions.bed.gz.csi"
    spectre_test_fasta_file      = params.pipelines_testdata_base_path + "longraredisease/genome_22/genome_22.fasta"
    spectre_test_clair3_vcf      = params.pipelines_testdata_base_path + "longraredisease/spectre/test_clair3.vcf.gz"
}

aws {
    client {
        anonymous = true
    }
}

// Disable all Nextflow reporting options
timeline { enabled = false }
report   { enabled = false }
trace    { enabled = false }
dag      { enabled = false }

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}
