nextflow_workflow {

    name "Test workflow CALL_CNV"
    script "../main.nf"
    workflow "CALL_CNV"
    config "./nextflow.config"

    tag "subworkflows"
    tag "subworkflows_local"
    tag "call_cnv"
    tag "spectre"

    test("Run SPECTRE CNV with real data") {
        options "-stub"
        when {
            workflow {
                """
                // ch_input_bam - empty for Spectre test
                input[0] = Channel.empty()

                // ch_mosdepth_summary
                input[1] = Channel.of([
                    [ id:'test_sample'],
                    file('https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/spectre/test.mosdepth.summary.txt', checkIfExists: true)
                ])

                // ch_mosdepth_regions_bed
                input[2] = Channel.of([
                    [ id:'test_sample' ],
                    file('https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/spectre/test.regions.bed.gz', checkIfExists: true)
                ])

                // ch_mosdepth_regions_csi
                input[3] = Channel.of([
                    [ id:'test_sample' ],
                    file('https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/spectre/test.regions.bed.gz.csi', checkIfExists: true)
                ])

                // ch_snv_vcf
                input[4] = Channel.of([
                    [ id:'test_sample' ],
                    file('https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/spectre/test_clair3.vcf.gz', checkIfExists: true)
                ])

                // ch_snv_phased_vcf - empty for Spectre test
                input[5] = Channel.empty()

                // ch_fasta
                input[6] = Channel.of([
                    [ id:'reference' ],
                    file('s3://ngi-igenomes/igenomes/Homo_sapiens/NCBI/GRCh38/Sequence/WholeGenomeFasta/genome.fa', checkIfExists: true),
                    file('s3://ngi-igenomes/igenomes/Homo_sapiens/NCBI/GRCh38/Sequence/WholeGenomeFasta/genome.fa.fai', checkIfExists: true)
                ])
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.vcf.size() > 0 },
                { assert workflow.out.tbi.size() > 0 },
                { assert workflow.out.vcf.get(0).get(1).endsWith("vcf.gz") },
                { assert workflow.out.tbi.get(0).get(1).endsWith("tbi") },
                { assert snapshot(
                    workflow.out.vcf.collect { meta, vcf -> [ 'vcf:', meta, file(vcf).name ] }
                ).match() }
            )
        }
    }

    test("Run SPECTRE CNV minimal test - stub") {

        options "-stub"

        when {
            workflow {
                """
                // ch_input_bam
                input[0] = Channel.empty()

                // ch_mosdepth_summary
                input[1] = Channel.of([
                    [ id:'test_sample'],
                    file('test.mosdepth.summary.txt')
                ])

                // ch_mosdepth_regions_bed
                input[2] = Channel.of([
                    [ id:'test_sample' ],
                    file('test.regions.bed.gz')
                ])

                // ch_mosdepth_regions_csi
                input[3] = Channel.of([
                    [ id:'test_sample' ],
                    file('test.regions.bed.gz.csi')
                ])

                // ch_snv_vcf
                input[4] = Channel.of([
                    [ id:'test_sample' ],
                    file('test_snv.vcf.gz')
                ])

                // ch_snv_phased_vcf
                input[5] = Channel.empty()

                // ch_fasta
                input[6] = Channel.of([
                    [ id:'reference' ],
                    file('genome.fa'),
                    file('genome.fa.fai')
                ])
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.vcf.size() > 0 }
            )
        }
    }
}
