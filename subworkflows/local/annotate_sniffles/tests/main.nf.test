nextflow_workflow {

    name "Test Workflow ANNOTATE_SNIFFLES"
    script "../main.nf"
    workflow "ANNOTATE_SNIFFLES"
    config "./nextflow.config"

    tag "subworkflows"
    tag "subworkflows_local"
    tag "annotate_sniffles"
    tag "annotsv"

    test("ANNOTATE_SNIFFLES with HPO terms - stub") {

        options "-stub"

        when {
            params {
                rankfiltering = "3-5,NA"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'test_sample' ],
                    file('test_sniffles.vcf')
                ])
                input[1] = Channel.of([
                    [ id:'test_sample' ],
                    'HP:0001250;HP:0000252'
                ])
                input[2] = Channel.of([
                    [ id:'test_sample' ],
                    file('test_snv.vcf')
                ])
                input[3] = Channel.value([
                    [ id:'annotsv_annotations' ],
                    file('annotsv_annotations')
                ]).collect()
                input[4] = null
                input[5] = null
                input[6] = null
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.vcf.size() > 0 },
                { assert workflow.out.tsv.size() > 0 },
                { assert workflow.out.versions.size() > 0 }
            )
        }
    }

    test("ANNOTATE_SNIFFLES with all optional files - stub") {

        options "-stub"

        when {
            params {
                rankfiltering = "3-5,NA"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'test_sample' ],
                    file('test_sniffles.vcf')
                ])
                input[1] = Channel.of([
                    [ id:'test_sample' ],
                    'HP:0001250;HP:0000252'
                ])
                input[2] = Channel.of([
                    [ id:'test_sample' ],
                    file('test_snv.vcf')
                ])
                input[3] = Channel.value([
                    [ id:'annotsv_annotations' ],
                    file('annotsv_annotations')
                ]).collect()
                input[4] = 'candidate_genes.txt'
                input[5] = 'false_positive_snv.txt'
                input[6] = 'gene_transcripts.txt'
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.vcf.size() > 0 },
                { assert workflow.out.tsv.size() > 0 },
                { assert workflow.out.versions.size() > 0 }
            )
        }
    }

    test("ANNOTATE_SNIFFLES minimal test - stub") {

        options "-stub"

        when {
            params {
                rankfiltering = "3-5,NA"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'test_sample' ],
                    file('test_sniffles.vcf')
                ])
                input[1] = Channel.of([
                    [ id:'test_sample' ],
                    ''
                ])
                input[2] = Channel.of([
                    [ id:'test_sample' ],
                    file('test_snv.vcf')
                ])
                input[3] = Channel.value([
                    [ id:'annotsv_annotations' ],
                    file('annotsv_annotations')
                ]).collect()
                input[4] = null
                input[5] = null
                input[6] = null
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success }
            )
        }
    }
}
