params {
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
    outdir = "tests/results"
    straglr_bed = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/straglr/str.test.bed"
}

docker {
    enabled = true
    runOptions = '-u $(id -u):$(id -g)'
}

process{
withName: 'CALL_STR:STRAGLR' {
        container = "ghcr.io/nourmahfel/str-ont:1.4.5"
        ext.prefix = { "${meta.id}_straglr" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/straglr" },
            mode: 'copy'
        ]
    }

withName: 'CALL_STR:BCFTOOLS_SORT_STRAGLR' {
        ext.prefix = { "${meta.id}_straglr_sorted" }
        ext.args = '-Oz --write-index=tbi'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/straglr" },
            mode: 'copy'
        ]
    }
}
