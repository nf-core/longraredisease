params {
    modules_testdata_base_path         = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
    pipelines_testdata_base_path       = 'https://raw.githubusercontent.com/nf-core/test-datasets/'
    longraredisease_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/'
}

process {
    withName: 'SNIFFLES' {
        ext.args   = { "--minsupport 1 --sample-id ${meta.id}" }
        ext.prefix = { "${meta.id}" }
    }

    withName: 'TRIO_CONCORDANCE_SV:SNIFFLES_TRIO' {
        ext.prefix = { "${meta.id}_trio" }
    }

    withName: 'TRIO_CONCORDANCE_SV:RTG_MENDELIAN_SV' {
        ext.prefix = { "${meta.id}_mendelian" }
    }

    withName: 'TRIO_CONCORDANCE_SV:RTG_VIOLATIONS_SV' {
        ext.prefix = { "${meta.id}_denovo" }
    }
}
