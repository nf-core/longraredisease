nextflow_workflow {

    name "Test Workflow BAM2FASTQ"
    script "../main.nf"
    workflow "BAM2FASTQ"
    config "./nextflow.config"

    tag "subworkflows"
    tag "subworkflows_local"
    tag "bam2fastq"
    tag "samtools"
    tag "samtools/merge"
    tag "samtools/fastq"

    test("single bam - converts to fastq") {

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'test', is_multiple: false ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/nanopore/bam/test.sorted.bam', checkIfExists: true)
                ])
                input[1] = Channel.empty()
                input[2] = Channel.empty()
                input[3] = Channel.empty()
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.other,
                    workflow.out.versions
                ).match() }
            )
        }
    }

    test("multiple bams - merges then converts to fastq") {

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'test', is_multiple: true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test2.paired_end.sorted.bam', checkIfExists: true)
                    ]
                ])
                input[1] = Channel.empty()
                input[2] = Channel.empty()
                input[3] = Channel.empty()
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.fastq,
                    workflow.out.versions
                ).match() }
            )
        }
    }

    test("single bam - stub") {

        options "-stub"

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'test', is_multiple: false ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/nanopore/bam/test.sorted.bam', checkIfExists: true)
                ])
                input[1] = Channel.empty()
                input[2] = Channel.empty()
                input[3] = Channel.empty()
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }
    }

    test("multiple bams - stub") {

        options "-stub"

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'test', is_multiple: true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test2.paired_end.sorted.bam', checkIfExists: true)
                    ]
                ])
                input[1] = Channel.empty()
                input[2] = Channel.empty()
                input[3] = Channel.empty()
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }
    }
}
