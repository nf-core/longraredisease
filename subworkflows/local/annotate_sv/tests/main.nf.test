    test("ANNOTATE_SV with null HPO terms - stub") {

        options "-stub"

        when {
            params {
                rankfiltering = "3-5,NA"
            }
            workflow {
                """
                // ch_samplesheet
                input[0] = Channel.of([
                    [ id:'test_sample' ],
                    [ hpo_terms: 'HP:0001250;HP:0000252' ]
