params {
    modules_testdata_base_path         = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
    longraredisease_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/'
}

process {
    withName: 'TRIO_CONCORDANCE_SNV:RTG_MENDELIAN_SNV' {
        ext.prefix = { "${meta.id}_mendelian" }
    }

    withName: 'TRIO_CONCORDANCE_SNV:RTG_VIOLATIONS_SNV' {
        ext.prefix = { "${meta.id}_denovo" }
    }
}
