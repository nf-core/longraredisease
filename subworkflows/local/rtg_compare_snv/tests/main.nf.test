nextflow_workflow {

    name "Test subworkflow RTG_COMPARE_SNV"
    script "../main.nf"
    workflow "RTG_COMPARE_SNV"
    config "./nextflow.config"

    tag "subworkflows"
    tag "subworkflows_local"
    tag "rtg_compare_snv"
    tag "rtg"

    test("trio vcf, sdf, ped - real data") {

        setup {
            run("RTGTOOLS_FORMAT") {
                script "../../../../modules/nf-core/rtgtools/format/main.nf"
                process {
                    """
                    input[0] = Channel.of([
                        [ id:'genome', single_end:true ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true),
                        [],
                        []
                    ])
                    """
                }
            }
        }

        when {
            workflow {
                """
                input[0] = RTGTOOLS_FORMAT.out.sdf
                input[1] = Channel.of([
                    [ id:'trio' ],
                    file(params.longraredisease_testdata_base_path + 'trio_testdata/trio.vcf.gz', checkIfExists: true)
                ])
                input[2] = Channel.of([
                    [ id:'trio' ],
                    file(params.longraredisease_testdata_base_path + 'trio_testdata/trio.ped', checkIfExists: true)
                ])
                """
            }
        }

        then {
            def countVcfVariants = { vcfPath ->
                def count = 0
                def is = new java.util.zip.GZIPInputStream(new java.io.FileInputStream(vcfPath.toString()))
                new java.io.BufferedReader(new java.io.InputStreamReader(is)).withCloseable { r ->
                    def line; while ((line = r.readLine()) != null) { if (!line.startsWith('#')) count++ }
                }
                count
            }
            assertAll(
                { assert workflow.success },
                { assert workflow.out.mendelian_vcf_sv.size() > 0 },
                { assert workflow.out.denovo_vcf_sv.size() > 0 },
                // 2 variants are inherited (Mendelian-consistent)
                { assert countVcfVariants(workflow.out.mendelian_vcf_sv.get(0).get(1)) == 2 },
                // 1 de novo variant (child carries ALT, neither parent does) is flagged as inconsistent
                { assert countVcfVariants(workflow.out.denovo_vcf_sv.get(0).get(1)) == 1 },
                { assert snapshot(
                    workflow.out.mendelian_vcf_sv.collect { meta, vcf -> [ meta, file(vcf).name ] },
                    workflow.out.denovo_vcf_sv.collect    { meta, vcf -> [ meta, file(vcf).name ] },
                    workflow.out.versions
                ).match() }
            )
        }

    }

    test("multisample vcf, sdf, ped - stub") {

        options "-stub"

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'genome' ],
                    file('genome.sdf')
                ])
                input[1] = Channel.of([
                    [ id:'test' ],
                    file('test.vcf.gz')
                ])
                input[2] = Channel.of([
                    [ id:'test' ],
                    file('family.ped')
                ])
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.mendelian_vcf_sv.size() > 0 },
                { assert workflow.out.denovo_vcf_sv.size() > 0 },
                { assert workflow.out.mendelian_vcf_sv.get(0).get(1).endsWith("vcf.gz") },
                { assert workflow.out.denovo_vcf_sv.get(0).get(1).endsWith("vcf.gz") },
                { assert snapshot(
                    workflow.out.mendelian_vcf_sv.collect { meta, vcf -> [ meta, file(vcf).name ] },
                    workflow.out.denovo_vcf_sv.collect    { meta, vcf -> [ meta, file(vcf).name ] }
                ).match() }
            )
        }

    }

}
