nextflow_workflow {

    name "Test subworkflow RTG_COMPARE_SNV"
    script "../main.nf"
    workflow "RTG_COMPARE_SNV"
    config "./nextflow.config"

    tag "subworkflows"
    tag "subworkflows_local"
    tag "rtg_compare_snv"
    tag "rtg"

    test("trio vcf, sdf, ped - stub") {

        options "-stub"

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'genome' ],
                    file('genome.sdf')
                ])
                input[1] = Channel.of([
                    [ id:'trio' ],
                    file('trio.vcf.gz')
                ])
                input[2] = Channel.of([
                    [ id:'trio' ],
                    file('family.ped')
                ])
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.mendelian_vcf_sv.size() > 0 },
                { assert workflow.out.denovo_vcf_sv.size() > 0 },
                { assert workflow.out.mendelian_vcf_sv.get(0).get(1).endsWith("vcf.gz") },
                { assert workflow.out.denovo_vcf_sv.get(0).get(1).endsWith("vcf.gz") },
                { assert snapshot(
                    workflow.out.mendelian_vcf_sv.collect { meta, vcf -> [ meta, file(vcf).name ] },
                    workflow.out.denovo_vcf_sv.collect    { meta, vcf -> [ meta, file(vcf).name ] }
                ).match() }
            )
        }

    }

    test("multisample vcf, sdf, ped - stub") {

        options "-stub"

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'genome' ],
                    file('genome.sdf')
                ])
                input[1] = Channel.of([
                    [ id:'test' ],
                    file('test.vcf.gz')
                ])
                input[2] = Channel.of([
                    [ id:'test' ],
                    file('family.ped')
                ])
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.mendelian_vcf_sv.size() > 0 },
                { assert workflow.out.denovo_vcf_sv.size() > 0 },
                { assert workflow.out.mendelian_vcf_sv.get(0).get(1).endsWith("vcf.gz") },
                { assert workflow.out.denovo_vcf_sv.get(0).get(1).endsWith("vcf.gz") },
                { assert snapshot(
                    workflow.out.mendelian_vcf_sv.collect { meta, vcf -> [ meta, file(vcf).name ] },
                    workflow.out.denovo_vcf_sv.collect    { meta, vcf -> [ meta, file(vcf).name ] }
                ).match() }
            )
        }

    }

}
