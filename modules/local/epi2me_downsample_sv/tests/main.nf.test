nextflow_process {

    name "Test Process DOWNSAMPLE_SV"
    script "../main.nf"
    process "DOWNSAMPLE_SV"
    config "./nextflow.config"

    tag "modules"
    tag "modules_local"
    tag "epi2me_downsample_sv"

    test("homo_sapiens - vcf, mosdepth summary, bed - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test', caller:'sniffles' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/vcf/sv_query.vcf.gz', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/vcf/sv_query.vcf.gz.tbi', checkIfExists: true)
                ]
                input[1] = [
                    [ id:'test' ],
                    file('test.mosdepth.summary.txt')
                ]
                input[2] = [
                    [ id:'test' ],
                    file('test.regions.bed.gz')
                ]
                input[3] = ['chr1', 'chr2', 'chr3']
                input[4] = 3
                input[5] = 10
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.filterbycov_vcf.size() > 0 },
                { assert process.out.filterbycov_vcf.get(0).get(1).toString().endsWith(".vcf.gz") },
                { assert process.out.filterbycov_vcf.get(0).get(2).toString().endsWith(".vcf.gz.tbi") },
                { assert snapshot(
                    file(process.out.filterbycov_vcf.get(0).get(1)).name,
                    process.out.versions
                ).match() }
            )
        }
    }
}
