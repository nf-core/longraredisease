// Global default params, used in configs

params {
    // ========================================
    // MAIN ANALYSIS TOGGLES
    // ========================================
    input                       = "${projectDir}/assets/samplesheet.csv"
    input_type                  = 'ubam'
    sequencing_platform         = 'ont'
    minimap2_model              = null
    use_winnowmap               = false
    winnowmap_model             = null
    haplotag_bam                = true
    trio_analysis               = false
    filter_targets              = false
    targets_bed                 = null
    generate_bam_stats          = true
    generate_coverage_report    = true
    sv                          = true
    snv                         = true
    cnv                         = false
    str                         = true
    qc                          = false
    methyl                      = false
    fasta_file                  = "s3://ngi-igenomes/igenomes/Homo_sapiens/NCBI/GRCh38/Sequence/WholeGenomeFasta/genome.fa"
    winnowmap_kmers             = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/annotation_data/repetitive_k15.txt"


    // References
    genome                     = null
    igenomes_base              = 's3://ngi-igenomes/igenomes/'
    igenomes_ignore            = false

    // ========================================
    // SV Running PARAMETERS
    // ========================================
    sniffles_min_mapq       = 20
    annotate_sv             = true
    annotate_svim           = false
    rankfiltering           = '1-5,NA'
    run_svim                = true
    svim_min_mapq           = 20
    filter_pass_sv          = true
    downsample_sv           = false
    coverage_bed            = null
    min_read_support        = 'auto'
    min_read_support_limit  = 2
    annotsv_annotations     = null

    // ===========================================================
    // Prioritize SVs with HPO
    // ===========================================================
    run_svanna               = false //requires hpo terms
    svanna_db                = "s3://annotation-cache/svanna_db/1.0.4"
    output_format            = "html"

    // ========================================
    // SV Running PARAMETERS
    // ========================================
    min_caller_support      = 2
    merge_sv                = true
    cutesv_min_mapq         = 20

    // ========================================
    // REFERENCE FILES
    // ========================================
    sniffles_tandem_file        = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/annotation_data/sniffles_no_alt_analysis_set.trf.bed"
    chromosome_codes            = [
        'chr1','chr2','chr3','chr4','chr5','chr6','chr7','chr8','chr9','chr10',
        'chr11','chr12','chr13','chr14','chr15','chr16','chr17','chr18','chr19','chr20',
        'chr21','chr22','chrX','chrY','chrMT'
    ]

    // ========================================
    // SNV CALLING PARAMETERS
    // ========================================
    run_deepvariant                 = false // may lead to memory issues
    filter_pass_snv                 = true
    clair3_min_mq                   = 10
    clair3_model                    = 'ont'
    clair3_platform                 = 'ont'
    deepvariant_regions             = null
    deepvariant_runtime_report      = true
    deepvariant_make_examples_extra_args = 'min_mapping_quality=10'
    annotate_clair3                 = true
    snpeff_db                       = 'GRCh38.mane.1.2.ensembl'

    // ========================================
    // CNV CALLING PARAMETERS
    // ========================================
    hificnv_exclude_bed        = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/annotation_data/hificnv_data/cnv.excluded_regions.common_50.hg38.bed.gz"
    hificnv_expected_cn_bed    = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/annotation_data/hificnv_data/expected_cn.hg38.XY.bed"

    // Spectre parameters
    spectre_bin_size           = 1000
    use_test_data               = false
    spectre_metadata            = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/annotation_data/spectre_metadata.mdr"
    spectre_blacklist           = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/annotation_data/spectre_blacklist.bed"

    // Spectre test parameters
    spectre_test_summary_txt     = null
    spectre_test_regions_bed     = null
    spectre_test_regions_csi     = null
    spectre_test_fasta_file      = null
    spectre_test_clair3_vcf      = null

    // ========================================
    // STR ANALYSIS PARAMETERS
    // ========================================
    straglr_bed                 = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/annotation_data/straglr_repeats.bed"
    trgt_bed                    = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/annotation_data/trgt_repeat_catalog.hg38.bed"
    variant_catalogue           = "https://raw.githubusercontent.com/nf-core/test-datasets/longraredisease/annotation_data/annotate_str/variant_catalog_hg38.json"

    // ========================================
    // OUTPUT FORMAT PARAMETERS
    // ========================================
    vcf_output                  = true
    snf_output                  = true

    // Unify STR, SV, CNV and annotate
    unify_vcf                   = true
    modify_str_calls            = true
    annotate_unified_vcf        = true

    // Boilerplate options
    outdir                       = null
    publish_dir_mode             = 'copy'
    email                        = null
    email_on_fail                = null
    plaintext_email              = false
    monochrome_logs              = false
    hook_url                     = null

    // Help parameters - needed for nf-schema plugin
    help                         = false
    help_full                    = false
    show_hidden                  = false
    version                      = false
    validate_params              = true

    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/'
    trace_report_suffix          = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')

    // MultiQC options
    multiqc_config             = null
    multiqc_logo               = null
    max_multiqc_email_size     = '25.MB'
    multiqc_methods_description = null

    // Config options
    config_profile_name        = null
    config_profile_description = null
    custom_config_version      = 'master'
    custom_config_base         = "https://raw.githubusercontent.com/nf-core/configs/${params.custom_config_version}"
    config_profile_contact     = null
    config_profile_url         = null
}

includeConfig 'conf/base.config'
includeConfig params.custom_config_base && (!System.getenv('NXF_OFFLINE') || !params.custom_config_base.startsWith('http')) ? "${params.custom_config_base}/nfcore_custom.config" : "/dev/null"

profiles {
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }
    conda {
        conda.enabled           = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        conda.channels          = ['conda-forge', 'bioconda']
        apptainer.enabled       = false
    }
    mamba {
        conda.enabled           = true
        conda.useMamba          = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    docker {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }
    arm64 {
        process.arch            = 'arm64'
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container'
    }
    emulate_amd64 {
        docker.runOptions       = '-u $(id -u):$(id -g) --platform=linux/amd64'
    }
    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        conda.enabled           = false
        docker.enabled          = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    podman {
        podman.enabled          = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    shifter {
        shifter.enabled         = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    charliecloud {
        charliecloud.enabled    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        apptainer.enabled       = false
    }
    apptainer {
        apptainer.enabled       = true
        apptainer.autoMounts    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
    }
    wave {
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container'
    }
    gpu {
        docker.runOptions       = '-u $(id -u):$(id -g) --gpus all'
        apptainer.runOptions    = '--nv'
        singularity.runOptions  = '--nv'
    }
    gitpod {
        executor.name           = 'local'
        executor.cpus           = 4
        executor.memory         = 8.GB
        process {
            resourceLimits = [
                memory: 8.GB,
                cpus  : 4,
                time  : 1.h
            ]
        }
    }

    test        { includeConfig 'conf/test.config'       }
    test_fastq  { includeConfig 'conf/test_fastq.config' }
    test_ubam   { includeConfig 'conf/test_ubam.config'  }
    test_full   { includeConfig 'conf/test_full.config'  }
}

// Load nf-core/longraredisease custom profiles from different institutions.
// TODO nf-core: Optionally, you can add a pipeline-specific nf-core config at https://github.com/nf-core/configs
includeConfig params.custom_config_base && (!System.getenv('NXF_OFFLINE') || !params.custom_config_base.startsWith('http')) ? "${params.custom_config_base}/pipeline/longraredisease.config" : "/dev/null"

// Set default registry for Apptainer, Docker, Podman, Charliecloud and Singularity independent of -profile
// Will not be used unless Apptainer / Docker / Podman / Charliecloud / Singularity are enabled
// Set to your registry if you have a mirror of containers
apptainer.registry    = 'quay.io'
docker.registry       = 'quay.io'
podman.registry       = 'quay.io'
singularity.registry  = 'quay.io'
charliecloud.registry = 'quay.io'

// Load igenomes.config if required
includeConfig !params.igenomes_ignore ? 'conf/igenomes.config' : 'conf/igenomes_ignored.config'

// Export these variables to prevent local Python/R libraries from conflicting with those in the container
// The JULIA depot path has been adjusted to a fixed path `/usr/local/share/julia` that needs to be used for packages in the container.
// See https://apeltzer.github.io/post/03-julia-lang-nextflow/ for details on that. Once we have a common agreement on where to keep Julia packages, this is adjustable.

env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
    JULIA_DEPOT_PATH = "/usr/local/share/julia"
}

// Set bash options
process.shell = [
    "bash",
    "-C",         // No clobber - prevent output redirection from overwriting files.
    "-e",         // Exit if a tool returns a non-zero status/exit code
    "-u",         // Treat unset variables and parameters as an error
    "-o",         // Returns the status of the last command to exit..
    "pipefail"    //   ..with a non-zero status or zero if all successfully execute
]

// Disable process selector warnings by default. Use debug profile to enable warnings.
nextflow.enable.configProcessNamesValidation = false

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${params.trace_report_suffix}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${params.trace_report_suffix}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${params.trace_report_suffix}.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${params.trace_report_suffix}.html"
}

manifest {
    name            = 'nf-core/longraredisease'
    contributors    = [
        // TODO nf-core: Update the field with the details of the contributors to your pipeline. New with Nextflow version 24.10.0
        [
            name: 'Nour Mahfel',
            affiliation: '',
            email: '',
            github: '',
            contribution: [], // List of contribution types ('author', 'maintainer' or 'contributor')
            orcid: ''
        ],
    ]
    homePage        = 'https://github.com/nf-core/longraredisease'
    description     = """A Nextflow pipeline for rare disease diagnostics from Oxford Nanopore long-read sequencing data. Includes SV, SNV, CNV, and methylation profiling."""
    mainScript      = 'main.nf'
    defaultBranch   = 'master'
    nextflowVersion = '!>=25.04.0'
    version         = '1.0.0'
    doi             = ''
}

// Nextflow plugins
plugins {
    id 'nf-schema@2.7.2' // Validation of pipeline parameters and creation of an input channel from a sample sheet
}

validation {
    defaultIgnoreParams = ["genomes"]
    monochromeLogs = params.monochrome_logs
}
// Load modules.config for DSL2 module specific options
includeConfig 'conf/modules.config'
