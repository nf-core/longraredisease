// Global default params, used in configs
trace.fields = "task_id,hash,native_id,script"

params {
    // ========================================
    // MAIN ANALYSIS TOGGLES
    // ========================================
    input                       = "${projectDir}/assets/samplesheet.csv"
    input_type                  = 'ubam'
    sequencing_platform         = 'ont'
    minimap2_model              = null
    use_winnowmap               = false
    winnowmap_model             = null
    haplotag_bam                = true
    trio_analysis               = true
    filter_targets              = false
    targets_bed                 = null
    generate_bam_stats          = true
    generate_coverage_report    = true
    sv                          = true
    snv                         = true
    cnv                         = true
    str                         = true
    qc                          = true
    methyl                      = true
    fasta_file                  = "s3://ngi-igenomes/igenomes/Homo_sapiens/NCBI/GRCh38/Sequence/WholeGenomeFasta/genome.fa"
    winnowmap_kmers             = "${projectDir}/assets/data/repetitive_k15.txt"

    // ========================================
    // SV Running PARAMETERS
    // ========================================
    sniffles_min_mapq       = 10
    annotate_sv             = true
    rankfiltering           = '1-5,NA'
    run_svim                = true
    svim_min_mapq           = 10
    filter_pass_sv          = true
    downsample_sv           = false
    coverage_bed            = null
    min_read_support        = 'auto'
    min_read_support_limit  = 2
    annotsv_annotations     = null

    // ===========================================================
    // Prioritize SVs with HPO
    // ===========================================================
    run_svanna               = true
    svanna_db                = "s3://my-nanoraredx-bucket/svanna_db"
    output_format            = "html"

    // ========================================
    // SV Running PARAMETERS
    // ========================================
    min_caller_support      = 2
    merge_sv                = true
    cutesv_min_mapq         = 10

    // ========================================
    // REFERENCE FILES
    // ========================================
    sniffles_tandem_file        = "${projectDir}/assets/data/sniffles_no_alt_analysis_set.trf.bed"
    chromosome_codes            = [
        'chr1','chr2','chr3','chr4','chr5','chr6','chr7','chr8','chr9','chr10',
        'chr11','chr12','chr13','chr14','chr15','chr16','chr17','chr18','chr19','chr20',
        'chr21','chr22','chrX','chrY','chrMT'
    ]

    // ========================================
    // SNV CALLING PARAMETERS
    // ========================================
    run_deepvariant                 = true
    filter_pass_snv                 = true
    clair3_min_mq                   = 10
    clair3_model                    = 'ont'
    clair3_platform                 = 'ont'
    deepvariant_regions             = null
    deepvariant_runtime_report      = true
    deepvariant_make_examples_extra_args = 'min_mapping_quality=10'
    annotate_clair3                 = true
    snpeff_db                       = 'GRCh38.mane.1.2.ensembl'

    // ========================================
    // CNV CALLING PARAMETERS
    // ========================================
    hificnv_exclude_bed        = "${projectDir}/assets/data/hificnv_data/cnv.excluded_regions.common_50.hg38.bed.gz"
    hificnv_expected_cn_bed    = "${projectDir}/assets/data/hificnv_data/expected_cn.hg38.XY.bed"

    // Spectre parameters
    spectre_bin_size           = 1000
    use_test_data               = false
    spectre_metadata            = "${projectDir}/assets/data/spectre_metadata.mdr"
    spectre_blacklist           = "${projectDir}/assets/data/spectre_blacklist.bed"

    // Spectre test parameters
    spectre_test_summary_txt     = null
    spectre_test_regions_bed     = null
    spectre_test_regions_csi     = null
    spectre_test_fasta_file      = null
    spectre_test_clair3_vcf      = null

    // ========================================
    // STR ANALYSIS PARAMETERS
    // ========================================
    straglr_bed                 = "${projectDir}/assets/data/straglr_repeats.bed"
    trgt_bed                    = "${projectDir}/assets/data/trgt_repeat_catalog.hg38.bed"
    variant_catalogue           = "${projectDir}/assets/data/annotate_str/variant_catalog_hg38.json"

    // ========================================
    // OUTPUT FORMAT PARAMETERS
    // ========================================
    vcf_output                  = true
    snf_output                  = true

    // Unify STR, SV, CNV and annotate
    unify_vcf                   = true
    modify_str_calls            = true
    annotate_unified_vcf        = true

    // Boilerplate options
    outdir                       = './results'
    publish_dir_mode             = 'copy'
    email                        = null
    email_on_fail                = null
    plaintext_email              = true
    monochrome_logs              = false
    hook_url                     = null

    // Help parameters - needed for nf-schema plugin
    help                         = false
    help_full                    = false
    show_hidden                  = false
    version                      = false
    validate_params              = true

    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/'
    trace_report_suffix          = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')

    // Config options
    config_profile_name        = null
    config_profile_description = null
    custom_config_version      = 'master'
    custom_config_base         = "https://raw.githubusercontent.com/nf-core/configs/${params.custom_config_version}"
    config_profile_contact     = null
    config_profile_url         = null
}

aws {
    client {
        anonymous = true
    }
    region = 'eu-north-1'
}

includeConfig 'conf/base.config'
includeConfig params.custom_config_base && (!System.getenv('NXF_OFFLINE') || !params.custom_config_base.startsWith('http')) ? "${params.custom_config_base}/nfcore_custom.config" : "/dev/null"

profiles {
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }
    conda {
        conda.enabled           = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        conda.channels          = ['conda-forge', 'bioconda']
        apptainer.enabled       = false
    }
    mamba {
        conda.enabled           = true
        conda.useMamba          = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    docker {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }
    arm {
        docker.runOptions       = '-u $(id -u):$(id -g) --platform=linux/amd64'
    }
    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        conda.enabled           = false
        docker.enabled          = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    podman {
        podman.enabled          = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    shifter {
        shifter.enabled         = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    charliecloud {
        charliecloud.enabled    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        apptainer.enabled       = false
    }
    apptainer {
        apptainer.enabled       = true
        apptainer.autoMounts    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
    }
    wave {
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container'
    }
    gitpod {
        executor.name           = 'local'
        executor.cpus           = 4
        executor.memory         = 8.GB
        process {
            resourceLimits = [
                memory: 8.GB,
                cpus  : 4,
                time  : 1.h
            ]
        }
    }
    test    { includeConfig  'conf/test.config' }
    test_fastq      { includeConfig  'conf/test_fastq.config' }
    test_ubam      { includeConfig  'conf/test_ubam.config' }
    test_full    { includeConfig  'conf/test_full.config' }
}

// Load base.config by default for all pipelines
cleanup  = false

// Set default registry for Apptainer, Docker, Podman, Charliecloud and Singularity independent of -profile
apptainer.registry    = 'quay.io'
docker.registry       = 'quay.io'
podman.registry       = 'quay.io'
singularity.registry  = 'quay.io'
charliecloud.registry = 'quay.io'

env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
    JULIA_DEPOT_PATH = "/usr/local/share/julia"
}

// Set bash options
process.shell = [
    "bash",
    "-C",         // No clobber - prevent output redirection from overwriting files.
    "-e",         // Exit if a tool returns a non-zero status/exit code
    "-u",         // Treat unset variables and parameters as an error
    "-o",         // Returns the status of the last command to exit..
    "pipefail"    //   ..with a non-zero status or zero if all successfully execute
]

// Disable process selector warnings by default. Use debug profile to enable warnings.
nextflow.enable.configProcessNamesValidation = false

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${params.trace_report_suffix}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${params.trace_report_suffix}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${params.trace_report_suffix}.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${params.trace_report_suffix}.html"
}

manifest {
    name            = 'nf-core/longraredisease'
    author          = """Nour Mahfel"""
    contributors    = [
        [
            name: 'Nour Mahfel',
            affiliation: 'Birmingham Womens Hospital, Birmingham University School of Medicine, Manchester University Genomic Medicine',
            email: 'nour.mahfel1@nhs.net',
            github: 'https://github.com/nourmahfel',
            contribution: ['contributor', 'maintainer', 'author']
        ]
        ]
    homePage        = 'https://github.com/nf-core/longraredisease'
    description     = """A Nextflow pipeline for rare disease diagnostics from Oxford Nanopore and pacbio long-read sequencing data. Includes SV, SNV, CNV, and methylation profiling."""
    mainScript      = 'main.nf'
    defaultBranch   = 'master'
    nextflowVersion = '!>=25.04.6'
    version         = '1.0.0'
    doi             = ''
}

// Nextflow plugins
plugins {
    id 'nf-schema@2.3.0'
}

validation {
    parametersSchema = 'nextflow_schema.json'
    help {
        enabled = true
        command = 'nextflow run main.nf --help'
        beforeText = """
-\033[2m----------------------------------------------------\033[0m-
                                        \033[0;32m,--.\033[0;30m/\033[0;32m,-.\033[0m
\033[0;34m        ___     __   __   __   ___     \033[0;32m/,-._.--~\'\033[0m
\033[0;34m  |\\ | |__  __ /  ` /  \\ |__) |__         \033[0;33m}  {\033[0m
\033[0;34m  | \\| |       \\__, \\__/ |  \\ |___     \033[0;32m\\`-._,-`-,\033[0m
                                        \033[0;32m`._,._,\'\033[0m
\033[0;35m  nf-core/longraredisease 1.0.0\033[0m
-\033[2m----------------------------------------------------\033[0m-
"""
        afterText = """
* The nf-core framework
    https://doi.org/10.1038/s41587-020-0439-x

* Software dependencies
    https://github.com/nf-core/longraredisease/blob/master/CITATIONS.md
"""
    }
    summary {
        beforeText = """
-\033[2m----------------------------------------------------\033[0m-
                                        \033[0;32m,--.\033[0;30m/\033[0;32m,-.\033[0m
\033[0;34m        ___     __   __   __   ___     \033[0;32m/,-._.--~\'\033[0m
\033[0;34m  |\\ | |__  __ /  ` /  \\ |__) |__         \033[0;33m}  {\033[0m
\033[0;34m  | \\| |       \\__, \\__/ |  \\ |___     \033[0;32m\\`-._,-`-,\033[0m
                                        \033[0;32m`._,._,\'\033[0m
\033[0;35m  nf-core/longraredisease 1.0.0\033[0m
-\033[2m----------------------------------------------------\033[0m-
"""
        afterText = """
* The nf-core framework
    https://doi.org/10.1038/s41587-020-0439-x

* Software dependencies
    https://github.com/nf-core/longraredisease/blob/master/CITATIONS.md
"""
    }
}

// Load modules.config for DSL2 module specific options
includeConfig 'conf/modules.config'
