/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${meta.id}" },
        mode: 'copy',
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        enabled: true
    ]

    withName: 'CREATE_PEDIGREE_FILE' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/pedigree_file" },
            mode: 'copy'
        ]
    }
    withName: 'SAMTOOLS_FASTQ' {
        ext.args = '-T MM,ML,mv --threads 8'
        cpus = 4
        publishDir = [
            pattern: '*_other.fastq.gz',
            mode: 'copy',
            path: { "${params.outdir}/${meta.id}/fastq_files" }
        ]
    }

    withName: 'SAMTOOLS_MERGE' {
        ext.args = '--threads 8'
        cpus = 4
        publishDir = [
            path: { "${params.outdir}/${meta.id}/unmapped_bam" },
            mode: 'copy'
        ]
    }

    withName: 'SAMTOOLS_INDEX' {
        ext.args = '--threads 10'
        cpus = 4
        publishDir = [
            path: { "${params.outdir}/${meta.id}/unmapped_bam" },
            mode: 'copy'
        ]
    }

    withName: 'CAT_FASTQ' {
        cpus = 4
        publishDir = [
            mode: 'copy',
            path: { "${params.outdir}/${meta.id}/fastq_files" }
        ]
    }

    withName: 'MINIMAP2_INDEX' {
        cpus = 8
        publishDir = [
            path: { "${params.outdir}/${meta.id}/mapped_bam" },
            mode: 'copy'
        ]
    }

    withName: 'MINIMAP2_ALIGN' {
    ext.args = {
        def presets = [
            ont: 'map-ont',
            hifi: 'map-hifi',
            accurate: 'lr:hq'
        ]
        def preset = presets[params.sequencing_platform] ?: 'map-ont'
        "-Y -y -ax ${preset} -R '@RG\\tID:${meta.id}\\tSM:${meta.id}\\tPL:${params.sequencing_platform.toUpperCase()}'"
    }
    cpus = 20
    memory = '64.GB'
    time = '120.h'
    publishDir = [
        path: { "${params.outdir}/${meta.id}/mapped_bam" },
        mode: 'copy'
    ]
}

    withName: 'WINNOWMAP_ALIGN' {
        ext.args = { "-ax map-ont " }
        // ext.args = { "-ax map-ont -R '@RG\\tID:${meta.id}\\tSM:${meta.id}\\tPL:ONT'" }
        cpus = 8
        publishDir = [
            path: { "${params.outdir}/${meta.id}/mapped_bam" },
            mode: 'copy'
        ]
    }


    withName: 'NANOPLOT' {
        ext.args = '--alength -t 32 --huge'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/nanoplot_qc" },
            mode: 'copy'
        ]
    }

    withName: 'SAMTOOLS_STATS' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/bam_stats" },
            mode: 'copy'
        ]
    }

    withName: 'SAMTOOLS_FLAGSTAT' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/bam_stats" },
            mode: 'copy'
        ]
    }

    withName: 'SAMTOOLS_IDXSTATS' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/bam_stats" },
            mode: 'copy'
        ]
    }

    withName: 'MOSDEPTH' {
        ext.args = '--fast-mode --by 1000'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/mosdepth" },
            mode: 'copy'
        ]
    }

    withName: 'MULTIQC_MOSDEPTH' {
        ext.prefix = { "${meta.id}_multiqc" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/multiqc_mosdepth" },
            mode: 'copy'
        ]
    }
    withName: 'MOSDEPTH_COV' {
        ext.args = '-n --quantize 0:1:10:30:'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/mosdepth" },
            mode: 'copy'
        ]
    }

    withName: 'MODKIT_PILEUP' {
        // ext.args = '--bedgraph'
        ext.prefix = { "${meta.id}_methyl" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/methyl" },
            mode: 'copy'
        ]
    }

    withName: 'MODKIT_PILEUP_CPG' {
        ext.args = '--cpg'
        ext.prefix = { "${meta.id}_cpg.methyl" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/methyl" },
            mode: 'copy'
        ]
    }
    withName: 'MODKIT_BEDGRAPH' {
        ext.args = '--bedgraph'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/methyl_bedgraph" },
            mode: 'copy'
        ]
    }

    withName: 'MODKIT_BEDGRAPH_CPG' {
        ext.args = '--cpg --bedgraph'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/methyl_bedgraph" },
            mode: 'copy'
        ]
    }

    withName: 'SVIM' {
        ext.prefix = { "${meta.id}_svim" }
        ext.args = [
            '--min_mapq 10',
            '--tandem_duplications_as_insertions',
            '--interspersed_duplications_as_insertions',
            '--insertion_sequences',
            '--types DEL,INS,INV'
            ].join(' ')
        publishDir = [
            path: { "${params.outdir}/${meta.id}/svim" },
            mode: 'copy',
            pattern: '*.vcf'
        ]
    }

    withName: 'BCFTOOLS_SORT_SVIM' {
        ext.prefix = { "${meta.id}_svim" }
        ext.args = '-Oz --write-index=tbi'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/svim" },
            mode: 'copy'
        ]
    }

    withName: 'CUTESV' {
        ext.prefix = { "${meta.id}_cutesv" }
        ext.args = '--min_mapq 10 --genotype'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/cutesv" },
            mode: 'copy',
            pattern: '*.vcf'
        ]
    }

    withName: 'RE2SUPPORT' {
        ext.prefix = { "${meta.id}" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/cutesv" },
            mode: 'copy',
            pattern: '*.vcf'
        ]
    }

    withName: 'BCFTOOLS_SORT_CUTESV' {
        ext.prefix = { "${meta.id}_cutesv" }
        ext.args = '-Oz --write-index=tbi'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/cutesv" },
            mode: 'copy'
        ]
    }

    withName: 'SNIFFLES' {
        ext.args = {"--mapq 10 --sample-id=${meta.id}"}
        ext.prefix = { "${meta.id}_sniffles" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/sniffles" },
            mode: 'copy'
        ]
    }

    // withName: 'SNIFFLES_GENOTYPE' {
    //     ext.args = {"--genotype-vcf ${meta.id}_sniffles.vcf"}
    //     ext.prefix = { "${meta.id}_sniffles" }
    //     publishDir = [
    //         path: { "${params.outdir}/${meta.id}/sniffles" },
    //         mode: 'copy'
    //     ]
    // }


    // Filter by coverage

    withName: 'BCFTOOLS_FILTER_SV' {
        ext.prefix = { "${meta.id}.${meta.caller}.filtered" }
        ext.args = '--threads 10 -f PASS -Oz --write-index=tbi'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/filtered_pass_sv" },
            mode: 'copy'
        ]
    }

    withName: 'DOWNSAMPLE_SV' {
        ext.prefix = { "${meta.id}.${meta.caller}.downsampled" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/downsampled_sv" },
            mode: 'copy'
        ]
    }

    withName: 'GUNZIP_SNIFFLES' {
        ext.prefix = { "${meta.id}_sniffles" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/unzippedSV_vcfs" },
            mode: 'copy'
        ]
    }

    withName: 'GUNZIP_CUTESV' {
        ext.prefix = { "${meta.id}_cutesv" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/unzippedSV_vcfs" },
            mode: 'copy'
        ]
    }

    withName: 'GUNZIP_SVIM' {
        ext.prefix = { "${meta.id}_svim" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/unzippedSV_vcfs" },
            mode: 'copy'
        ]
    }

    withName: 'GUNZIP_SV' {
        ext.prefix = { "${meta.id}_final_sv" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/unzippedSV_vcfs" },
            mode: 'copy'
        ]
    }

    withName: 'JASMINESV' {
        ext.args = 'min_support=2 --output_genotypes --keep_var_ids'
        ext.prefix = { "${meta.id}_merged" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/merged_sv" },
            mode: 'copy'
        ]
    }

    withName: 'NORMALIZE_JASMINE' {
        ext.prefix = { "${meta.id}_normalized" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/merged_sv" },
            mode: 'copy'
        ]
    }

    withName: 'BCFTOOLS_SORT_JASMINE' {
        ext.args = '-Oz --write-index=tbi'  // Compress and create .tbi index
        ext.prefix = { "${meta.id}_sorted" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/merged_sv" },
            mode: 'copy',
        ]
    }

    // Extract single sample (uncompressed for further processing)
    withName: 'BCFTOOLS_VIEW_JASMINE' {
        ext.args = { "-s \$(bcftools query -l ${vcf} | head -1) -Oz --write-index=tbi" }  // Uncompressed output
        ext.prefix = { "${meta.id}_single" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/merged_sv" },
            mode: 'copy'
        ]
    }

    // Reheader (uncompressed)
    withName: 'BCFTOOLS_REHEADER_JASMINE' {
        ext.prefix = { "${meta.id}.wf_sv" }
        // ext.args = '-s <(echo "${meta.id}")'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/merged_sv" },
            mode: 'copy'
        ]
    }

    withName: 'TABIX_JASMINE' {
        ext.prefix = { "${meta.id}.wf_sv" }
        ext.args = '-f -p vcf'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/merged_sv" },
            mode: 'copy'
        ]
    }


    withName: 'SVANNA_PRIORITIZE' {
        ext.prefix = { "${meta.id}_svanna" }
        ext.output_format = params.output_format
        publishDir = [
            path: { "${params.outdir}/${meta.id}/svanna" },
            mode: 'copy'
        ]
    }

    withName: 'SV_PLOT_SNIFFLES' {
        ext.prefix = { "${meta.id}_sniffles_info_plots" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/sv_info_plots" },
            mode: 'copy'
        ]
    }
    withName: 'SV_PLOT_SVIM' {
        ext.prefix = { "${meta.id}_svim_info_plots" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/sv_info_plots" },
            mode: 'copy'
        ]
    }

    withName: 'SV_PLOT_CUTESV' {
        ext.prefix = { "${meta.id}_cutesv_info_plots" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/sv_info_plots" },
            mode: 'copy'
        ]
    }

    withName: 'CLAIR3' {
        ext.args   = { params.trio_analysis ? "--gvcf --sample_name=${meta.id}" : "--sample_name=${meta.id}" }
        ext.prefix = { "${meta.id}_clair3" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/clair3" },
            mode: 'copy'
            // pattern: '*.{vcf,vcf.gz}'
        ]
    }

    withName: 'CLAIR3_FIX' {
        ext.prefix = { "${meta.id}_clair3_merge_fixed" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/clair3" },
            mode: 'copy'
        ]
    }

    withName: 'GLNEXUS' {
        ext.prefix = { "${meta.id}_glnexus" }
        ext.args = '--threads 10 --trim-uncalled-alleles'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/glnexus" },
            mode: 'copy'
        ]
    }

    withName: 'RTGTOOLS_FORMAT' {
        ext.prefix = { "${meta.id}_rtg" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/rtg_sdf" },
            mode: 'copy'
        ]
    }

    withName: 'RTGTOOLS_MENDELIAN' {
        ext.prefix = { "${meta.id}_mendelian" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/rtg_mendelian" },
            mode: 'copy'
        ]
    }

    withName: 'RTGTOOLS_DENOVO' {
        ext.prefix = { "${meta.id}_denovo" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/rtg_denovo" },
            mode: 'copy'
        ]
    }

    withName: 'BCFTOOLS_FILTER_CLAIR3' {
        ext.prefix = { "${meta.id}_clair3_merge_filtered" }
        ext.args = '--threads 10 -f PASS -Oz --write-index=tbi'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/clair3" },
            mode: 'copy'
        ]
    }

    withName: 'DEEPVARIANT_RUNDEEPVARIANT'{
        ext.prefix = { "${meta.id}_deepvariant" }
        ext.args = '--model_type=ONT_R104 --vcf_stats_report=true --disable_small_model=true --logging_dir=${PWD}/logs --dry_run=false --regions=chr22'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/deepvariant" },
            mode: 'copy'
        ]
    }

    withName: 'BCFTOOLS_FILTER_DEEPVARIANT' {
        ext.prefix = { "${meta.id}_deepvariant_filtered" }
        ext.args = '--threads 10 -f PASS -Oz --write-index=tbi'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/deepvariant" },
            mode: 'copy'
        ]
    }

    withName: 'LONGPHASE_PHASE'{
        ext.prefix = { "${meta.id}_longphase" }
        ext.args = '--ont'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/longphase" },
            mode: 'copy'
        ]
    }

    // Use bcftools isec instead works much better
    withName: 'BCFTOOLS_CONCAT_SNV' {
        ext.prefix = { "${meta.id}.wf_snp" }
        ext.args = '--rm-dups all --write-index=tbi --allow-overlaps --threads 10'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/merged_SNV" },
            mode: 'copy'
        ]
    }

    withName: 'SPECTRE' {
        // ext.args =  '--bin-size 1000'
        ext.prefix = { "${meta.id}_spectre" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/spectre" },
            mode: 'copy'
        ]
    }

    withName: 'BCFTOOLS_SORT_SPECTRE' {
        ext.prefix = { "${meta.id}.wf_cnv" }
        ext.args = '-Oz --write-index=tbi'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/spectre" },
            mode: 'copy'
        ]
    }

    withName: 'ROUND_DP' {
        ext.prefix = { "${meta.id}_rounddp_spectre" }
        ext.args = '--threads 10'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/spectre" },
            mode: 'copy'
        ]
    }

    withName: 'HIFICNV' {
        ext.args =  '--disable-vcf-filters'
        errorStrategy = 'ignore'
        ext.prefix = { "${meta.id}.hificnv" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/hificnv" },
            mode: 'copy'
        ]
    }

    withName: 'BCFTOOLS_SORT_HIFICNV' {
        ext.prefix = { "${meta.id}.wf_cnv" }
        ext.args = '-Oz --write-index=tbi'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/hificnv" },
            mode: 'copy'
        ]
    }

    withName: 'STRAGLR' {
        ext.prefix = { "${meta.id}_straglr" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/straglr" },
            mode: 'copy'
        ]
    }

    withName: 'STRANGER' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/stranger" },
            mode: 'copy'
        ]
    }

    withName: 'BCFTOOLS_SORT_STRAGLR' {
        ext.prefix = { "${meta.id}_straglr_sorted" }
        ext.args = '-Oz'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/straglr" },
            mode: 'copy'
        ]
    }

    withName: 'ANNOTATE_STR' {
        ext.prefix = { "${meta.id}.wf_str" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/straglr" },
            mode: 'copy'
        ]
    }

    withName: 'ANNOTSV' {
        ext.args   = "-vcf 1 -genomeBuild GRCh38"
        ext.prefix = { "${meta.id}_annotsv" }
        containerOptions = '--user root'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/annotsv" },
            mode: 'copy'
        ]
    }

    withName: 'UNIFYVCF' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/unified_SV_CNV_STR" },
            mode: 'copy'
        ]
    }

    // for scientists to view the unified VCF
    withName: 'GUNZIP_UNIFY' {
        ext.prefix = { "${meta.id}_unify" }
        ext.args = '-c'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/unified_SV_CNV_STR" },
            mode: 'copy'
        ]
    }
}
